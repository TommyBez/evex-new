# Optional outside Vercel. On Vercel, AI Gateway can authenticate through OIDC.
AI_GATEWAY_API_KEY=

# App-runtime secret used by run_vercel_cli for sandbox network-policy
# credential brokering. This token is injected at the firewall and must never be
# written into sandbox files, shell commands, or generated agent source.
VERCEL_BROKER_TOKEN=

# Optional when testing preview deployments protected by Vercel Deployment Protection.
VERCEL_AUTOMATION_BYPASS_SECRET=

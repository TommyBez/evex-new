{
  "name": "evex",
  "version": "0.1.0",
  "private": false,
  "author": "TommyBez",
  "homepage": "https://evex.sh",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "pnpm --filter ./apps/web db:generate",
    "db:migrate": "pnpm --filter ./apps/web db:migrate",
    "db:push": "pnpm --filter ./apps/web db:push",
    "db:studio": "pnpm --filter ./apps/web db:studio",
    "check": "turbo run check",
    "dev": "turbo run dev --filter=./apps/web",
    "email:preview": "pnpm --filter ./apps/web email:preview",
    "fix": "turbo run fix",
    "start": "pnpm --filter ./apps/web start",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.8.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
